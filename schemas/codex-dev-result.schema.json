{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "summary",
    "changed_files",
    "verification",
    "risks",
    "requires_approval"
  ],
  "properties": {
    "summary": { "type": "string" },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "not_run"]
          },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requires_approval": { "type": "boolean" }
  },
  "additionalProperties": false
}
