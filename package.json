{
  "name": "office-ai-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "core:scan": "tsx core/src/cli/scan.ts --config config/sources.local.json",
    "core:context": "tsx core/src/cli/context-demo.ts",
    "core:plan": "tsx core/src/cli/plan-demo.ts",
    "core:route": "tsx core/src/cli/route-demo.ts",
    "dev:auto": "tsx core/src/cli/dev-automation.ts",
    "core:test": "tsx --test core/tests/*.test.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "lucide-react": "^0.468.0",
    "vite": "^6.1.0",
    "typescript": "~5.7.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.2"
  }
}
