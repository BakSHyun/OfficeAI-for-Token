{
  "name": "office-ai-command-center",
  "private": true,
  "version": "0.1.0",
  "description": "토큰 최적화 AI 업무 오케스트레이션 데스크톱 앱",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "app:dev": "electron-vite dev",
    "app:build": "electron-vite build",
    "app:package": "electron-vite build && node scripts/build-icons.mjs && electron-builder",
    "app:package:win": "electron-vite build && node scripts/build-icons.mjs && electron-builder --win",
    "app:package:mac": "electron-vite build && node scripts/build-icons.mjs && electron-builder --mac",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "core:scan": "tsx core/src/cli/scan.ts --config config/sources.local.json",
    "core:context": "tsx core/src/cli/context-demo.ts",
    "core:plan": "tsx core/src/cli/plan-demo.ts",
    "core:route": "tsx core/src/cli/route-demo.ts",
    "core:run": "tsx core/src/cli/run.ts",
    "dev:auto": "tsx core/src/cli/dev-automation.ts",
    "core:test": "tsx --test core/tests/*.test.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "better-sqlite3": "^12.11.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.2"
  },
  "build": {
    "appId": "com.officeai.app",
    "productName": "OfficeAI",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
